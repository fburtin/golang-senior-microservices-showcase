FROM golang:1.26-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build \
    -o /customer-consumer \
    ./cmd/customer-consumer

FROM alpine:3.20

RUN adduser -D -H appuser

COPY --from=builder /customer-consumer /customer-consumer

USER appuser

ENTRYPOINT ["/customer-consumer"]